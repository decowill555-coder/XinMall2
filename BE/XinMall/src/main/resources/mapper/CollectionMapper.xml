<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.xinmall.mapper.system.CollectionMapper">

    <select id="selectUserGoodsCollections" resultType="com.example.xinmall.entity.system.UserCollection">
        SELECT c.* FROM collection c
        WHERE c.user_id = #{userId} AND c.target_type = 1
        ORDER BY c.created_at DESC
    </select>

    <select id="countUserGoodsCollections" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM collection
        WHERE user_id = #{userId} AND target_type = 1
    </select>

</mapper>
