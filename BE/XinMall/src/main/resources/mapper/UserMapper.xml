<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.xinmall.mapper.UserMapper">

    <resultMap id="UserWithProfileMap" type="com.example.xinmall.entity.User">
        <id column="id" property="id"/>
        <result column="phone" property="phone"/>
        <result column="password" property="password"/>
        <result column="nickname" property="nickname"/>
        <result column="avatar" property="avatar"/>
        <result column="gender" property="gender"/>
        <result column="birthday" property="birthday"/>
        <result column="signature" property="signature"/>
        <result column="status" property="status"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="last_login_ip" property="lastLoginIp"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
        <association property="profile" javaType="com.example.xinmall.entity.UserProfile">
            <id column="profile_id" property="id"/>
            <result column="user_id" property="userId"/>
            <result column="real_name" property="realName"/>
            <result column="id_card" property="idCard"/>
            <result column="real_name_status" property="realNameStatus"/>
            <result column="shop_auth_status" property="shopAuthStatus"/>
        </association>
    </resultMap>

    <select id="selectByPhone" resultType="com.example.xinmall.entity.User">
        SELECT * FROM user 
        WHERE phone = #{phone} AND deleted = 0
    </select>

    <select id="selectUserWithProfile" resultMap="UserWithProfileMap">
        SELECT 
            u.*,
            up.id as profile_id,
            up.user_id,
            up.real_name,
            up.id_card,
            up.real_name_status,
            up.shop_auth_status
        FROM user u
        LEFT JOIN user_profile up ON u.id = up.user_id
        WHERE u.id = #{userId} AND u.deleted = 0
    </select>

    <update id="updateLoginInfo">
        UPDATE user 
        SET last_login_time = #{loginTime}, 
            last_login_ip = #{loginIp}
        WHERE id = #{userId}
    </update>

</mapper>
