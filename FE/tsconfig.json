{
  "compilerOptions": {
    "target": "esnext",
    "useDefineForClassFields": true,
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["esnext", "dom"],
    
    // [关键] 添加类型定义路径
    "types": [
      "@dcloudio/types", // uni-app 类型
      "vite/client",     // Vite 类型
      "node"             // Node.js 类型 (用于 path, __dirname)
    ],
    
    // [关键] 路径别名映射 (必须与 vite.config.ts 保持一致)
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "vite.config.ts" // [关键] 确保包含配置文件
  ]
}