{
	"easycom": {
	    "autoscan": true,
	    "custom": {
	      // 1. 原子组件 (Atoms)
	      "^UiButton": "@/ui-kit/atoms/UiButton.vue",
	      "^UiIcon": "@/ui-kit/atoms/UiIcon.vue",
	      "^UiText": "@/ui-kit/atoms/UiText.vue",
	      "^UiTag": "@/ui-kit/atoms/UiTag.vue",
	      
	      // 2. 分子组件 (Molecules)
	      "^UiInput": "@/ui-kit/molecules/UiInput.vue",
	      "^UiSearch": "@/ui-kit/molecules/UiSearch.vue",
	      "^UiNavbar": "@/ui-kit/molecules/UiNavbar.vue",
	
	      // 3. 组织组件 (Organisms)
	      "^UiCard": "@/ui-kit/organisms/UiCard.vue",
	      "^UiModal": "@/ui-kit/organisms/UiModal.vue",
	
	      // 4. 业务组件 (Layout)
	      "^The(.*)": "@/components/layout/The$1.vue"
	    }
	  },
	"pages": [ 
		// --- 1. Tabbar 页面 (主包) ---
		    {
		      "path": "pages/index/index",
		      "style": { "navigationBarTitleText": "首页", "navigationStyle": "custom" }
		    },
		    {
		      "path": "pages/follow/index",
		      "style": { "navigationBarTitleText": "关注", "navigationStyle": "custom" }
		    },
		    {
		      "path": "pages/message/index",
		      "style": { "navigationBarTitleText": "消息", "navigationStyle": "custom" }
		    },
		    {
		      "path": "pages/my/index",
		      "style": { "navigationBarTitleText": "我的", "navigationStyle": "custom" }
		    }
		  ],
		  
		  // --- 2. 分包配置 (Sub Packages) ---
		  "subPackages": [
		    {
		      "root": "pages-sub/seller",
		      "pages": [
		        {
		          "path": "publish/entry",
		          "style": { "navigationBarTitleText": "发布闲置" }
		        }
		      ]
		    },
		    {
		      "root": "pages-sub/trade",
		      "pages": [
		        {
		          "path": "product/detail",
		          "style": { "navigationBarTitleText": "商品详情" }
		        }
		      ]
		    }
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "uni-app",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	},
	"uniIdRouter": {},
	"tabBar": {
		"color": "#999999",
		"selectedColor": "#2979FF",
		"borderStyle": "white",
		"backgroundColor": "#ffffff",
		"list": [
		  {
			"pagePath": "pages/index/index",
			"text": "推荐"
		  },
		  {
			"pagePath": "pages/follow/index",
			"text": "关注"
		  },
		  // 注意：发布页虽然是特殊按钮，但也需要在这里占位，或者用一个空的页面占位
		  {
			"pagePath": "pages/publish/placeholder", 
			"text": "发布"
		  },
		  {
			"pagePath": "pages/message/index",
			"text": "消息"
		  },
		  {
			"pagePath": "pages/my/index",
			"text": "我的"
		  }
		]
	}
	
}
