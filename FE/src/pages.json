{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^UiButton": "@/ui-kit/atoms/UiButton.vue",
      "^UiIcon": "@/ui-kit/atoms/UiIcon.vue",
      "^UiText": "@/ui-kit/atoms/UiText.vue",
      "^UiTag": "@/ui-kit/atoms/UiTag.vue",
      "^UiAvatar": "@/ui-kit/atoms/UiAvatar.vue",
      "^UiBadge": "@/ui-kit/atoms/UiBadge.vue",
      "^UiDivider": "@/ui-kit/atoms/UiDivider.vue",
      "^UiImage": "@/ui-kit/atoms/UiImage.vue",
      "^UiPrice": "@/ui-kit/atoms/UiPrice.vue",
      "^UiSkeleton": "@/ui-kit/atoms/UiSkeleton.vue",
      "^UiInput": "@/ui-kit/molecules/UiInput.vue",
      "^UiSearch": "@/ui-kit/molecules/UiSearch.vue",
      "^UiNavbar": "@/ui-kit/molecules/UiNavbar.vue",
      "^UiCell": "@/ui-kit/molecules/UiCell.vue",
      "^UiCheckbox": "@/ui-kit/molecules/UiCheckbox.vue",
      "^UiRate": "@/ui-kit/molecules/UiRate.vue",
      "^UiStepper": "@/ui-kit/molecules/UiStepper.vue",
      "^UiSwitch": "@/ui-kit/molecules/UiSwitch.vue",
      "^UiTabs": "@/ui-kit/molecules/UiTabs.vue",
      "^UiUpload": "@/ui-kit/molecules/UiUpload.vue",
      "^UiSubNavbar": "@/ui-kit/molecules/UiSubNavbar.vue",
      "^UiCard": "@/ui-kit/organisms/UiCard.vue",
      "^UiModal": "@/ui-kit/organisms/UiModal.vue",
      "^UiActionSheet": "@/ui-kit/organisms/UiActionSheet.vue",
      "^UiDialog": "@/ui-kit/organisms/UiDialog.vue",
      "^UiGoodsCard": "@/ui-kit/organisms/UiGoodsCard.vue",
      "^UiPopup": "@/ui-kit/organisms/UiPopup.vue",
      "^UiToast": "@/ui-kit/organisms/UiToast.vue",
      "^UiWaterfalls": "@/ui-kit/organisms/UiWaterfalls.vue",
      "^The(.*)$": "@/components/layout/The$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "首页",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/follow/index",
      "style": {
        "navigationBarTitleText": "关注",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/message/index",
      "style": {
        "navigationBarTitleText": "消息",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/my/index",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/publish/placeholder",
      "style": {
        "navigationBarTitleText": "发布",
        "navigationStyle": "custom"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages-sub/trade",
      "pages": [
        { "path": "product/detail", "style": { "navigationBarTitleText": "商品详情", "navigationStyle": "custom" } },
        { "path": "product/list", "style": { "navigationBarTitleText": "商品列表", "navigationStyle": "custom" } },
        { "path": "cart/index", "style": { "navigationBarTitleText": "购物车", "navigationStyle": "custom" } },
        { "path": "order/list", "style": { "navigationBarTitleText": "我的订单", "navigationStyle": "custom" } },
        { "path": "order/detail", "style": { "navigationBarTitleText": "订单详情", "navigationStyle": "custom" } },
        { "path": "order/confirm", "style": { "navigationBarTitleText": "确认订单", "navigationStyle": "custom" } },
        { "path": "pay/index", "style": { "navigationBarTitleText": "支付", "navigationStyle": "custom" } },
        { "path": "evaluate/index", "style": { "navigationBarTitleText": "评价", "navigationStyle": "custom" } },
        { "path": "search/index", "style": { "navigationBarTitleText": "搜索", "navigationStyle": "custom" } }
      ]
    },
    {
      "root": "pages-sub/seller",
      "pages": [
        { "path": "publish/entry", "style": { "navigationBarTitleText": "发布闲置", "navigationStyle": "custom" } },
        { "path": "shop/index", "style": { "navigationBarTitleText": "我的店铺", "navigationStyle": "custom" } },
        { "path": "shop/manage", "style": { "navigationBarTitleText": "店铺管理", "navigationStyle": "custom" } },
        { "path": "goods/list", "style": { "navigationBarTitleText": "商品管理", "navigationStyle": "custom" } },
        { "path": "goods/edit", "style": { "navigationBarTitleText": "编辑商品", "navigationStyle": "custom" } },
        { "path": "after-sale/list", "style": { "navigationBarTitleText": "售后管理", "navigationStyle": "custom" } },
        { "path": "after-sale/detail", "style": { "navigationBarTitleText": "售后详情", "navigationStyle": "custom" } }
      ]
    },
    {
      "root": "pages-sub/content",
      "pages": [
        { "path": "post/detail", "style": { "navigationBarTitleText": "帖子详情", "navigationStyle": "custom" } },
        { "path": "post/publish", "style": { "navigationBarTitleText": "发布帖子", "navigationStyle": "custom" } },
        { "path": "topic/index", "style": { "navigationBarTitleText": "话题", "navigationStyle": "custom" } },
        { "path": "user/index", "style": { "navigationBarTitleText": "Ta的主页", "navigationStyle": "custom" } }
      ]
    },
    {
      "root": "pages-sub/user",
      "pages": [
        { "path": "login/index", "style": { "navigationBarTitleText": "登录", "navigationStyle": "custom" } },
        { "path": "address/list", "style": { "navigationBarTitleText": "收货地址", "navigationStyle": "custom" } },
        { "path": "address/edit", "style": { "navigationBarTitleText": "编辑地址", "navigationStyle": "custom" } },
        { "path": "collection/index", "style": { "navigationBarTitleText": "我的收藏", "navigationStyle": "custom" } },
        { "path": "history/index", "style": { "navigationBarTitleText": "浏览足迹", "navigationStyle": "custom" } },
        { "path": "settings/index", "style": { "navigationBarTitleText": "设置", "navigationStyle": "custom" } },
        { "path": "wallet/index", "style": { "navigationBarTitleText": "我的钱包", "navigationStyle": "custom" } }
      ]
    },
    {
      "root": "pages-sub/auth",
      "pages": [
        { "path": "real-name/index", "style": { "navigationBarTitleText": "实名认证", "navigationStyle": "custom" } },
        { "path": "shop-auth/index", "style": { "navigationBarTitleText": "店铺认证", "navigationStyle": "custom" } }
      ]
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "XinMall",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F2F4F8",
    "navigationStyle": "custom"
  },
  "uniIdRouter": {},
  "tabBar": {
    "custom": true,
    "color": "#999999",
    "height": "0px",
    "selectedColor": "#1ABC9C",
    "borderStyle": "white",
    "backgroundColor": "#FFFFFF",
    "list": [
      { "pagePath": "pages/index/index", "text": "首页" },
      { "pagePath": "pages/follow/index", "text": "关注" },
      { "pagePath": "pages/message/index", "text": "消息" },
      { "pagePath": "pages/my/index", "text": "我的" }
    ]
  }
}
