{
  "name": "xinmall-fe",
  "version": "1.0.0",
  "description": "XinMall - 垂直数码电商平台 (uni-app + Vue3 + TS)",
  "scripts": {
    "dev:h5": "uni",
    "dev:mp-weixin": "uni -p mp-weixin",
    "dev:app": "uni -p app",
    "build:h5": "uni build",
    "build:mp-weixin": "uni build -p mp-weixin",
    "build:app": "uni build -p app",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "dayjs": "^1.11.10",
    "decimal.js": "^10.4.3",
    "pinia": "^2.3.1",
    "vue": "^3.3.0",
    "vue-i18n": "^9.2.2"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.3",
    "@dcloudio/uni-app": "^3.0.0-alpha-3080220230511001",
    "@dcloudio/uni-app-plus": "^3.0.0-alpha-3080220230511001",
    "@dcloudio/uni-components": "^3.0.0-alpha-3080220230511001",
    "@dcloudio/uni-h5": "^3.0.0-alpha-3080220230511001",
    "@dcloudio/uni-mp-weixin": "^3.0.0-alpha-3080220230511001",
    "@dcloudio/vite-plugin-uni": "^3.0.0-alpha-3080220230511001",
    "@rushstack/eslint-patch": "^1.2.0",
    "@types/node": "^18.16.0",
    "@vitejs/plugin-vue": "^4.2.0",
    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/tsconfig": "^0.1.3",
    "eslint": "^8.39.0",
    "eslint-plugin-vue": "^9.11.0",
    "prettier": "^2.8.8",
    "sass": "^1.62.1",
    "typescript": "^5.0.2",
    "vite": "^5.2.8",
    "vue-tsc": "^1.6.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
